# --- Web Push (VAPID) ---
# Generate these once with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- Subscription store (Upstash Redis / Vercel KV) ---
# Adding the "Upstash for Redis" integration on Vercel sets these automatically.
# For a standalone Upstash DB you can instead use UPSTASH_REDIS_REST_URL / _TOKEN.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Required: lock down the cron endpoint ---
# /api/send-notifications refuses to run unless this is set (it dispatches pushes + spends quota).
# Vercel Cron sends it automatically as `Authorization: Bearer <CRON_SECRET>`. Any random string.
CRON_SECRET=

# --- Google Map Tiles API (basemap) ---
# Client key, served to the browser by api/config.js (so it stays out of the public repo).
# Restrict it by HTTP referrer + API in Google Cloud Console. Locally you can instead use config.js.
GMAPS_KEY=

# --- Native iOS push (APNs) ---
# Create an APNs Auth Key (.p8) in Apple Developer → Keys (enable "Apple Push Notifications
# service"). One key works for sandbox + production. The cron skips the iOS push pass entirely
# until the APNs key (APNS_KEY_P8_B64 or APNS_KEY_P8), APNS_KEY_ID and APNS_TEAM_ID are all set.
APNS_KEY_P8_B64=      # PREFERRED: base64 of the whole .p8 PEM (`base64 -i AuthKey_XXXX.p8`). Single-line,
                      # charset-safe — survives any env-var UI with no newline mangling. Wins over APNS_KEY_P8.
APNS_KEY_P8=          # FALLBACK (if not using _B64): full .p8 PEM incl. BEGIN/END lines (escaped \n auto-restored)
APNS_KEY_ID=         # 10-char Key ID shown when you created the key
APNS_TEAM_ID=69K2S3664V
APNS_BUNDLE_ID=guide.curb.ios
# APNS_HOST=api.push.apple.com   # default (production / TestFlight). Sandbox: api.development.push.apple.com
